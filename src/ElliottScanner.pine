//@version=6
indicator("Elliott Scanner Pro", overlay=true, max_labels_count=500, max_lines_count=500)

pivotLength = input.int(5, "Pivot Length", minval=2)
showPivots = input.bool(true, "Show Pivots")

ph = ta.pivothigh(high, pivotLength, pivotLength)
pl = ta.pivotlow(low, pivotLength, pivotLength)

plotshape(showPivots and not na(ph), style=shape.triangledown, location=location.abovebar)
plotshape(showPivots and not na(pl), style=shape.triangleup, location=location.belowbar)

//=========================
// ZigZag Engine
//=========================
var float lastHigh = na
var float lastLow = na

if not na(ph)
    lastHigh := ph

if not na(pl)
    lastLow := pl

plot(lastHigh, title="Last High")
plot(lastLow, title="Last Low")

//=========================
// Elliott Rule Engine
//=========================
impulseUp =
     not na(lastLow) and
     not na(lastHigh) and
     lastHigh > lastLow

correctionDown =
     not na(lastHigh) and
     close < lastHigh

bgcolor(impulseUp ? color.new(color.green,90) : na)
bgcolor(correctionDown ? color.new(color.red,90) : na)

//=========================
// Fibonacci Engine
//=========================
fibRange = math.abs(lastHigh - lastLow)

fib236 = lastHigh - fibRange * 0.236
fib382 = lastHigh - fibRange * 0.382
fib500 = lastHigh - fibRange * 0.500
fib618 = lastHigh - fibRange * 0.618
fib786 = lastHigh - fibRange * 0.786

plot(fib236, title="Fib 23.6")
plot(fib382, title="Fib 38.2")
plot(fib500, title="Fib 50")
plot(fib618, title="Fib 61.8")
plot(fib786, title="Fib 78.6")

//=========================
// Wave Counter
//=========================
var int waveCount = 0

if not na(ph) or not na(pl)
    waveCount += 1

waveCount := math.min(waveCount, 5)

label.new(
    bar_index,
    high,
    "W" + str.tostring(waveCount),
    style=label.style_label_down
)

//=========================
// Alternate Count Engine
//=========================
var int primaryScore = 0
var int alternateScore = 0

if impulseUp
    primaryScore += 2
else
    alternateScore += 1

if correctionDown
    alternateScore += 2

activeCount = primaryScore >= alternateScore ? "PRIMARY" : "ALTERNATE"

label.new(
    bar_index,
    low,
    activeCount,
    style=label.style_label_up
)

//=========================
// Confidence Scoring
//=========================
score = 0.0

score += impulseUp ? 40 : 0
score += correctionDown ? 20 : 0
score += not na(lastHigh) ? 20 : 0
score += not na(lastLow) ? 20 : 0

confidence = math.min(score, 100)

var table t = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(t, 0, 0, "Confidence: " + str.tostring(confidence) + "%")

//=========================
// Alert Engine
//=========================
bullishSignal = impulseUp and confidence >= 80
bearishSignal = correctionDown and confidence >= 80

alertcondition(bullishSignal,
    title="Bullish Setup",
    message="Bullish Elliott setup detected")

alertcondition(bearishSignal,
    title="Bearish Setup",
    message="Bearish Elliott setup detected")

//=========================
// TradingView Optimization
//=========================
showBackground = input.bool(true, "Show Trend Background")

trendColor =
     bullishSignal ? color.new(color.green, 85) :
     bearishSignal ? color.new(color.red, 85) :
     na

bgcolor(showBackground ? trendColor : na)

plotchar(bullishSignal,
    title="Bullish",
    char="▲",
    location=location.belowbar)

plotchar(bearishSignal,
    title="Bearish",
    char="▼",
    location=location.abovebar)

//=========================
// Multi-Timeframe Engine
//=========================
tfHigher = input.timeframe("240", "Higher Timeframe")

htfHigh = request.security(syminfo.tickerid, tfHigher, high)
htfLow  = request.security(syminfo.tickerid, tfHigher, low)
htfClose = request.security(syminfo.tickerid, tfHigher, close)

htfBull = htfClose > ta.sma(htfClose, 20)
htfBear = htfClose < ta.sma(htfClose, 20)

plot(htfHigh, title="HTF High")
plot(htfLow, title="HTF Low")

//=========================
// Elliott Rule Engine V6
//=========================
wave1Valid = lastHigh > lastLow
wave2Valid = close > lastLow
wave3Valid = lastHigh > nz(lastHigh[1], lastHigh)
wave4Valid = close > lastLow
wave5Valid = close > ta.sma(close, 20)

impulseValid =
     wave1Valid and
     wave2Valid and
     wave3Valid and
     wave4Valid and
     wave5Valid

plotchar(impulseValid,
    title="Impulse Valid",
    char="5",
    location=location.top)

alertcondition(
    impulseValid,
    title="Impulse Complete",
    message="Potential Elliott impulse detected")

//=========================
// Correction Pattern Engine
//=========================
abcCorrection =
     correctionDown and
     close > fib382 and
     close < fib618

flatCorrection =
     correctionDown and
     math.abs(close - lastLow) < fibRange * 0.1

triangleCorrection =
     ta.falling(high, 5) and
     ta.rising(low, 5)

correctionType =
     abcCorrection ? "ABC" :
     flatCorrection ? "FLAT" :
     triangleCorrection ? "TRIANGLE" :
     "NONE"

label.new(bar_index, low, correctionType, style=label.style_label_up)

alertcondition(abcCorrection,
     title="ABC Correction",
     message="ABC correction detected")

//=========================
// Fibonacci Projection Engine
//=========================
waveRange = math.abs(lastHigh - lastLow)

target100 = lastHigh + waveRange * 1.000
target127 = lastHigh + waveRange * 1.272
target161 = lastHigh + waveRange * 1.618
target200 = lastHigh + waveRange * 2.000
target261 = lastHigh + waveRange * 2.618

plot(target100, title="Target 1.000")
plot(target127, title="Target 1.272")
plot(target161, title="Target 1.618")
plot(target200, title="Target 2.000")
plot(target261, title="Target 2.618")

alertcondition(close >= target161,
    title="Wave Target",
    message="Price reached Fibonacci projection")

//=========================
// Wave Score Engine
//=========================
float waveScore = 0.0

waveScore += impulseValid ? 30 : 0
waveScore += abcCorrection ? 20 : 0
waveScore += htfBull ? 20 : 0
waveScore += confidence >= 80 ? 20 : 0
waveScore += close > target100 ? 10 : 0

waveScore := math.min(waveScore, 100)

var table scoreTable = table.new(position.bottom_right, 1, 1)
if barstate.islast
    table.cell(scoreTable, 0, 0, "Wave Score: " + str.tostring(waveScore))

alertcondition(waveScore >= 80,
    title="High Score",
    message="High-confidence Elliott setup")

//=========================
// Alternate Count Ranking
//=========================
primaryRank = waveScore
alternateRank = waveScore - 15

activeScenario = primaryRank >= alternateRank ? "PRIMARY" : "ALTERNATE"

var table scenarioTable = table.new(position.top_left, 1, 2)
if barstate.islast
    table.cell(scenarioTable, 0, 0, "Scenario")
    table.cell(scenarioTable, 0, 1, activeScenario)

alertcondition(activeScenario == "ALTERNATE",
    title="Alternate Count Active",
    message="Alternate Elliott count has become dominant")

//=========================
// Elliott Setup Scanner
//=========================
wave12Setup =
     impulseValid and
     htfBull and
     close > fib618

wave3Breakout =
     wave12Setup and
     close > lastHigh

abcCompletion =
     abcCorrection and
     close >= fib618

plotshape(wave12Setup,
     title="1-2 Setup",
     style=shape.circle,
     location=location.belowbar)

plotshape(wave3Breakout,
     title="Wave 3",
     style=shape.triangleup,
     location=location.belowbar)

alertcondition(wave12Setup,
     title="1-2 Setup",
     message="Potential Elliott 1-2 setup detected")

alertcondition(wave3Breakout,
     title="Wave 3 Breakout",
     message="Wave 3 breakout detected")

alertcondition(abcCompletion,
     title="ABC Complete",
     message="ABC correction completed")
