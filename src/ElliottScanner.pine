//@version=6
indicator("Elliott Scanner Pro", overlay=true)
pivotLength=input.int(5,"Pivot Length")
ph=ta.pivothigh(high,pivotLength,pivotLength)
pl=ta.pivotlow(low,pivotLength,pivotLength)
plotshape(not na(ph),style=shape.triangledown,location=location.abovebar)
plotshape(not na(pl),style=shape.triangleup,location=location.belowbar)
